# Local development defaults.
API_PORT=3001
PORT=3001
VITE_API_BASE=/api
VITE_API_PROXY_TARGET=http://127.0.0.1:3001

# SQLite database path. Relative paths are resolved from the project root.
DATABASE_PATH=data/meeting.db

# Seed demo meetings, tasks, templates, and departments on an empty database.
# Keep this false in production and Vercel preview deployments.
SEED_DATA=true

# Runtime mode examples:
# NODE_ENV=development
# VERCEL_ENV=preview
